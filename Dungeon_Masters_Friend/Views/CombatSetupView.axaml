<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:Dungeon_Masters_Friend.ViewModels"
             xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
			 x:Class="Dungeon_Masters_Friend.Views.CombatSetupView"
			 x:DataType="vm:CombatSetupViewModel">
	<TransitioningContentControl>
		<StackPanel HorizontalAlignment="Center">

			<!-- Add combatants stage -->
			<StackPanel IsVisible="{Binding !IsInInitiativeMode}" Spacing="10">
				<ListBox ItemsSource="{Binding DraftCombatants}" Height="300" MinWidth="400">
					<ListBox.ItemTemplate>
						<DataTemplate>
							<Grid ColumnDefinitions="*, Auto, Auto, Auto" ColumnSpacing="5">
								<TextBox Text="{Binding Entity.Name}" GotFocus="TextBox_GotFocus" Grid.Column="0" />
								<Button Command="{Binding $parent[UserControl].DataContext.EditCombatantCommand}" CommandParameter="{Binding}" Grid.Column="1">
									<Button.Content>
										<icons:MaterialIcon Kind="Pencil" />
									</Button.Content>
								</Button>
								<Button Command="{Binding $parent[UserControl].DataContext.DuplicateCombatantCommand}" CommandParameter="{Binding}" Grid.Column="2">
									<Button.Content>
										<icons:MaterialIcon Kind="ContentDuplicate" />
									</Button.Content>
								</Button>
								<Button Command="{Binding $parent[UserControl].DataContext.RemoveCombatantCommand}" CommandParameter="{Binding}" Grid.Column="3">
									<Button.Content>
										<icons:MaterialIcon Kind="Close" />
									</Button.Content>
								</Button>
							</Grid>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>
				<Button Content="Add Combatant" Command="{Binding AddCombatantCommand}" Margin="0, 10, 0, 0" />
				<Button Content="Clear" Command="{Binding ClearCombatantsCommand}" />
				<Button Content="Initiative" Command="{Binding ProceedToInitiativeCommand}" />
			</StackPanel>

			<!-- Determine initiative stage -->
			<StackPanel IsVisible="{Binding IsInInitiativeMode}" Spacing="10">
				<ListBox ItemsSource="{Binding DraftCombatants}" Height="300" MinWidth="400">
					<ListBox.ItemTemplate>
						<DataTemplate>
							<Grid ColumnDefinitions="*, 50">
								<TextBlock Text="{Binding Entity.Name}" Grid.Column="0" />
								<NumericUpDown
									Value="{Binding Initiative}"
									FormatString="N0"
									ParsingNumberStyle="Integer"
									AllowSpin="False"
									ShowButtonSpinner="False"
									Grid.Column="1" />
							</Grid>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>
				<Button Content="Back" Command="{Binding BackToCombatantDraftingCommand}" Margin="0, 10, 0, 0" />
				<Button Content="Start" Command="{Binding SubmitCommand}" />
			</StackPanel>

		</StackPanel>
	</TransitioningContentControl>
</UserControl>